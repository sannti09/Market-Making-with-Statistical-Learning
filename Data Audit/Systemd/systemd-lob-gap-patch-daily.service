[Unit]
Description=Daily LOB conservative gap patching
After=network-online.target lob-quality-daily.service
Wants=network-online.target

[Service]
Type=oneshot
User=lob
Group=lob
WorkingDirectory=/opt/lob_system
ExecStart=/opt/lob_system/venv/bin/python /opt/lob_system/scripts/run_daily_gap_patches_beta.py --root /opt/lob_system --skip-today
